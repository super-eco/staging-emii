    {
      "parameters": {
        "jsCode": "// TRF_BuildHealthReport - Monta relatório de saúde\nconst messages = $('DB_FetchRecentMessages').all().map(i => i.json);\nconst items = $('DB_FetchPendingItems').all().map(i => i.json);\n\nconst now = new Date();\nconst reportDate = now.toLocaleDateString('pt-BR');\nconst reportTime = now.toLocaleTimeString('pt-BR');\n\nconst totalMessages = messages.length;\nconst totalPending = items.length;\n\n// Contar itens atrasados\nconst overdueItems = items.filter(i => i.notify_at && new Date(i.notify_at) < now && !i.notified_at).length;\n\n// Contar por tipo de mensagem\nconst messagesByType = messages.reduce((acc, m) => {\n  acc[m.type] = (acc[m.type] || 0) + 1;\n  return acc;\n}, {});\n\n// Determinar status geral\nlet status = '✅ OK';\nlet alerts = [];\n\nif (overdueItems > 5) {\n  status = '⚠️ ATENÇÃO';\n  alerts.push(overdueItems + ' lembretes atrasados');\n}\n\nif (totalMessages === 0 && now.getHours() >= 8 && now.getHours() <= 22) {\n  alerts.push('Nenhuma mensagem nas últimas 6h (horário comercial)');\n}\n\nconst report = {\n  date: reportDate,\n  time: reportTime,\n  status: status,\n  metrics: {\n    messages_6h: totalMessages,\n    messages_by_type: messagesByType,\n    pending_items: totalPending,\n    overdue_reminders: overdueItems\n  },\n  alerts: alerts\n};\n\nreturn {\n  json: {\n    report: report,\n    should_alert: alerts.length > 0\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        304
      ],
      "id": "build-report",
      "name": "TRF_BuildHealthReport"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "should-alert",
              "leftValue": "={{ $json.should_alert }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        672,
        304
      ],
      "id": "check-alert",
      "name": "CHK_ShouldAlert"
    },
    {
      "parameters": {
        "jsCode": "// TRF_BuildAlertMessage - Monta mensagem de alerta\nconst report = $('TRF_BuildHealthReport').first().json.report;\n\nlet message = '🚨 *EMII Health Alert*\\n\\n';\nmessage += '📅 ' + report.date + ' ' + report.time + '\\n';\nmessage += 'Status: ' + report.status + '\\n\\n';\nmessage += '*Alertas:*\\n';\nreport.alerts.forEach(alert => {\n  message += '• ' + alert + '\\n';\n});\nmessage += '\\n*Métricas:*\\n';\nmessage += '• Mensagens (6h): ' + report.metrics.messages_6h + '\\n';\nmessage += '• Itens pendentes: ' + report.metrics.pending_items + '\\n';\nmessage += '• Lembretes atrasados: ' + report.metrics.overdue_reminders;\n\nreturn {\n  json: {\n    message: message,\n    tech_channel_phone: '5591984472580'\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        192
      ],
      "id": "build-alert",
      "name": "TRF_BuildAlertMessage"
    },
