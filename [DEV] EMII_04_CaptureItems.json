      "parameters": {
        "jsCode": "// Extract current item from batch\nconst inputData = $input.first().json;\nconst items = inputData.items || [];\nconst batchIndex = $input.context.nodesExecutionData['LOOP_Items'][0].executionData.contextData.batchIndex || 0;\nconst currentItem = items[batchIndex] || {};\n\nreturn [{\n  json: {\n    ...inputData,\n    current_item: currentItem,\n    item_index: batchIndex\n  }\n}];"
      },
