    {
      "parameters": {
        "jsCode": "// Prepare item for insertion\nconst inputData = $('TRF_ExtractCurrentItem').first().json;\nconst item = inputData.current_item;\nconst leadTime = inputData.lead_time_default_seconds || 900;\n\nlet notify_at = null;\nif (item.type === 'reminder' && item.due_at) {\n  const dueDate = new Date(item.due_at);\n  const notifyDate = new Date(dueDate.getTime() - (leadTime * 1000));\n  notify_at = notifyDate.toISOString();\n}\n\nreturn [{\n  json: {\n    owner_phone: inputData.owner_phone,\n    source_message_id: inputData.source_message_id,\n    type: item.type || 'task',\n    title: item.title || 'Sem título',\n    details: item.details || null,\n    status: 'open',\n    due_at: item.due_at || null,\n    notify_at: notify_at\n  }\n}];"
      },
