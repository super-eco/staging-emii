      ],
      "id": "trf-mark-skipped"
    },
    {
      "parameters": {
        "jsCode": "// Build summary text\nconst allData = $input.all();\nconst createdItems = allData.filter(d => d.json.item_created);\nconst createdCount = createdItems.length;\n\nlet summaryText = '';\nif (createdCount === 0) {\n  summaryText = '✅ Nenhum item novo criado (já existiam).';\n} else if (createdCount === 1) {\n  const item = createdItems[0].json.current_item;\n  summaryText = `✅ 1 item registrado: ${item.title}`;\n} else {\n  summaryText = `✅ ${createdCount} itens registrados:\\n`;\n  createdItems.forEach((d, idx) => {\n    const item = d.json.current_item;\n    summaryText += `(${idx + 1}) ${item.title}\\n`;\n  });\n}\n\nreturn [{\n  json: {\n    created_count: createdCount,\n    total_items: allData.length,\n    summary_text: summaryText.trim()\n  }\n}];"
      },
