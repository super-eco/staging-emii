        "jsCode": "// Mark as skipped (duplicate)\nconst inputData = $('TRF_ExtractCurrentItem').first().json;\nreturn [{\n  json: {\n    ...inputData,\n    item_created: false\n  }\n}];"
      },
      "name": "TRF_MarkSkipped",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
