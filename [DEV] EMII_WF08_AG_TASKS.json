        400
      ],
      "credentials": {
        "googleTasksOAuth2Api": {
          "id": "mw82h3M70MIvp8It",
          "name": "Infra_Tasks"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const envelope = $('TRG_FromOrchestrator').item.json.envelope;\nconst tasks = $input.all();\n\nif (tasks.length === 0) {\n  return [{\n    json: {\n      trace_id: envelope.trace_id,\n      draft: {\n        text: \"Você não tem tarefas pendentes. 🎉\",\n        payload: { provider: \"gtasks\", task_count: 0 }\n      },\n      signals: { needs_clarification: false }\n    }\n  }];\n}\n\nlet text = `Você tem ${tasks.length} tarefa(s) pendente(s):\\n\\n`;\ntasks.forEach((t, i) => {\n  const task = t.json;\n  const title = task.title || \"(sem título)\";\n  const due = task.due ? new Date(task.due).toLocaleDateString('pt-BR') : \"sem prazo\";\n  text += `${i+1}. ${title} — ${due}\\n`;\n});\n\nreturn [{\n  json: {\n    trace_id: envelope.trace_id,\n    draft: {\n      text: text,\n      payload: { provider: \"gtasks\", task_count: tasks.length }\n    },\n    signals: { needs_clarification: false }\n  }\n}];"
      },
      "id": "wf08-format-list",
      "name": "TRF_FormatListResult",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1632,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const envelope = $('TRG_FromOrchestrator').item.json.envelope;\nconst task = $input.first().json;\n\nconst title = task.title || \"Tarefa\";\nconst due = task.due ? `\\n📅 Prazo: ${new Date(task.due).toLocaleDateString('pt-BR')}` : \"\";\n\nconst text = `✅ Tarefa criada: ${title}${due}`;\n\nreturn [{\n  json: {\n    trace_id: envelope.trace_id,\n    draft: {\n      text: text,\n      payload: { provider: \"gtasks\", task_id: task.id }\n    },\n    signals: { needs_clarification: false }\n  }\n}];"
      },
