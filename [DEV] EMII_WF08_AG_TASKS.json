    {
      "parameters": {
        "jsCode": "const envelope = $('TRG_FromOrchestrator').item.json.envelope;\nconst intent = $('Agent_TasksIntent').item.json.output;\n\nreturn [{\n  json: {\n    trace_id: envelope.trace_id,\n    draft: {\n      text: intent.clarification_question || \"Preciso de mais informações sobre a tarefa.\",\n      payload: {}\n    },\n    signals: {\n      needs_clarification: true,\n      clarification_question: intent.clarification_question\n    }\n  }\n}];"
      },
